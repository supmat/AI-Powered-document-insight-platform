# =============================================================================
# AI-Powered Document Insight Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit your .env file to Git! It is already in .gitignore.
# =============================================================================

# -------------------------
# PostgreSQL Database
# -------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=             # REQUIRED: Set a strong password
POSTGRES_DB=document_insights
POSTGRES_SERVER=localhost

# -------------------------
# MinIO Object Storage
# -------------------------
MINIO_URL=localhost:9000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=           # REQUIRED: Set a strong password
MINIO_BUCKET_NAME=documents
MINIO_SECURE=false

# -------------------------
# RabbitMQ Message Broker
# -------------------------
RABBITMQ_USER=
RABBITMQ_PASSWORD=             # REQUIRED: Set a strong password
RABBITMQ_URL=amqp://admin:password@localhost:5672/
RABBITMQ_QUEUE_NAME=document_processing_queue

# -------------------------
# Google Gemini API
# -------------------------
# Get your key at: https://aistudio.google.com/app/apikey
# Leave blank to use local fallback models (EasyOCR + SentenceTransformers)
GEMINI_API_KEY=

# -------------------------
# Gateway JWT Security
# -------------------------
# REQUIRED: Generate with:  openssl rand -hex 32
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
